{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/capability/v1/security-profile.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln capability security profile",
    "type": "object",
    "additionalProperties": false,
    "required": [],
    "properties": {
        "filesystem_read_scopes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/capability/v1/scope.schema.json"
            }
        },
        "filesystem_write_scopes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/capability/v1/scope.schema.json"
            }
        },
        "process_execution_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "network_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "model_egress_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "external_integration_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "artifact_access_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "validation_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/rule"
            }
        },
        "default_deny_settings": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "filesystem_read": {
                    "type": "boolean"
                },
                "filesystem_write": {
                    "type": "boolean"
                },
                "process_execution": {
                    "type": "boolean"
                },
                "network_access": {
                    "type": "boolean"
                },
                "model_egress": {
                    "type": "boolean"
                },
                "external_integration_access": {
                    "type": "boolean"
                },
                "artifact_access": {
                    "type": "boolean"
                },
                "validation_access": {
                    "type": "boolean"
                }
            }
        }
    },
    "anyOf": [
        {
            "required": [
                "default_deny_settings"
            ]
        },
        {
            "required": [
                "filesystem_read_scopes"
            ]
        },
        {
            "required": [
                "filesystem_write_scopes"
            ]
        },
        {
            "required": [
                "process_execution_rules"
            ]
        },
        {
            "required": [
                "network_rules"
            ]
        },
        {
            "required": [
                "model_egress_rules"
            ]
        },
        {
            "required": [
                "external_integration_rules"
            ]
        },
        {
            "required": [
                "artifact_access_rules"
            ]
        },
        {
            "required": [
                "validation_rules"
            ]
        }
    ],
    "$defs": {
        "rule": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "rule_id",
                "effect",
                "priority",
                "scope",
                "capability"
            ],
            "properties": {
                "rule_id": {
                    "type": "string",
                    "minLength": 1
                },
                "effect": {
                    "type": "string",
                    "enum": [
                        "allow",
                        "deny"
                    ]
                },
                "priority": {
                    "type": "integer",
                    "minimum": 0
                },
                "capability": {
                    "type": "string",
                    "minLength": 1
                },
                "scope": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/capability/v1/scope.schema.json"
                },
                "conditions": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "time_range": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": [
                                "start_time",
                                "end_time"
                            ],
                            "properties": {
                                "start_time": {
                                    "type": "string",
                                    "format": "date-time"
                                },
                                "end_time": {
                                    "type": "string",
                                    "format": "date-time"
                                }
                            }
                        },
                        "approval_required": {
                            "type": "boolean"
                        },
                        "max_token_usage_count": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                }
            }
        }
    }
}