{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/model/v1/protocol-response.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln model protocol response",
    "description": "Model-scoped protocol response including provider-neutral usage, errors, and artifact references.",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/protocol-response.schema.json"
        },
        {
            "properties": {
                "operation": {
                    "type": "string",
                    "pattern": "^model\\."
                },
                "result": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/generate-result.schema.json"
                },
                "error": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/error.schema.json"
                },
                "usage": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/usage.schema.json"
                },
                "artifact_references": {
                    "type": "array",
                    "items": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
                    },
                    "minItems": 1,
                    "uniqueItems": true
                }
            }
        }
    ]
}