{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/model/v1/generate-result.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln model generate result",
    "description": "Provider-neutral result of model generation, including generated content, finish reason, usage, and optional support metadata.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "finish_reason",
        "usage"
    ],
    "properties": {
        "answer": {
            "description": "Generated textual answer, when returned inline.",
            "type": "string",
            "minLength": 1
        },
        "answer_artifact_reference": {
            "description": "Artifact reference for generated answer content, when not returned inline.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
        },
        "structured_output": {
            "description": "Provider-neutral structured output, when the response mode requested structured JSON.",
            "type": "object"
        },
        "tool_call_requests": {
            "description": "Tool calls requested by the model.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "tool_call_id",
                    "tool_name"
                ],
                "properties": {
                    "tool_call_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "tool_name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "arguments": {
                        "type": "object"
                    },
                    "arguments_artifact_reference": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
                    }
                },
                "oneOf": [
                    {
                        "required": [
                            "arguments"
                        ]
                    },
                    {
                        "required": [
                            "arguments_artifact_reference"
                        ]
                    }
                ]
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "finish_reason": {
            "description": "Provider-neutral reason generation stopped.",
            "type": "string",
            "enum": [
                "stop",
                "length",
                "tool_call",
                "content_filter",
                "canceled",
                "unknown"
            ]
        },
        "usage": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/usage.schema.json"
        },
        "response_artifact_reference": {
            "description": "Artifact reference for the raw model response.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
        },
        "citations": {
            "description": "Structured citations supporting generated content.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "citation_id",
                    "source_reference"
                ],
                "properties": {
                    "citation_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "source_reference": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
                    },
                    "quoted_text": {
                        "type": "string",
                        "minLength": 1
                    },
                    "source_range": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/source-range.schema.json"
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    }
                }
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "support_metadata": {
            "description": "Provider-neutral support metadata for generated claims, citations, or retrieval grounding.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "grounding_status": {
                    "type": "string",
                    "enum": [
                        "grounded",
                        "partially_grounded",
                        "ungrounded",
                        "not_evaluated"
                    ]
                },
                "support_artifact_references": {
                    "type": "array",
                    "items": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "unsupported_claim_count": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        }
    },
    "oneOf": [
        {
            "required": [
                "answer"
            ]
        },
        {
            "required": [
                "answer_artifact_reference"
            ]
        },
        {
            "required": [
                "structured_output"
            ]
        },
        {
            "required": [
                "tool_call_requests"
            ]
        }
    ]
}