{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/model/v1/protocol-request.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln model protocol request",
    "description": "Model-scoped protocol request carrying run, operation, capability, and budget context.",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/protocol-request.schema.json"
        },
        {
            "required": [
                "run_id",
                "operation_id"
            ],
            "properties": {
                "operation": {
                    "type": "string",
                    "pattern": "^model\\."
                },
                "run_id": {
                    "type": "string",
                    "minLength": 1
                },
                "turn_id": {
                    "type": "string",
                    "minLength": 1
                },
                "operation_id": {
                    "type": "string",
                    "minLength": 1
                },
                "capability_grant_id": {
                    "type": "string",
                    "minLength": 1
                },
                "budget_reservation_id": {
                    "type": "string",
                    "minLength": 1
                },
                "model_invocation_id": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    ]
}