{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/model/v1/generate-response.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln model generate response",
    "description": "Concrete successful model.generate protocol response wrapping a model generation result.",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/protocol-response.schema.json"
        },
        {
            "required": [
                "result"
            ],
            "properties": {
                "operation": {
                    "const": "model.generate"
                },
                "status": {
                    "const": "ok"
                },
                "result": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/generate-result.schema.json"
                }
            }
        }
    ]
}