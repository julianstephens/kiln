{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/session.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository session",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "session_id",
        "capabilities",
        "index_status"
    ],
    "properties": {
        "session_id": {
            "type": "string",
            "minLength": 1
        },
        "capabilities": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "repository": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/identifier.schema.json"
        },
        "index_status": {
            "type": "string",
            "minLength": 1
        }
    }
}