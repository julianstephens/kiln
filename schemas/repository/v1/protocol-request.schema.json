{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/protocol-request.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository protocol request",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/protocol-request.schema.json"
        },
        {
            "required": [
                "run_id"
            ],
            "properties": {
                "operation": {
                    "type": "string",
                    "pattern": "^repository\\."
                },
                "run_id": {
                    "type": "string",
                    "minLength": 1
                },
                "session_id": {
                    "type": "string",
                    "minLength": 1
                },
                "capability_grant_id": {
                    "type": "string",
                    "minLength": 1
                },
                "budget_reservation_id": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    ]
}