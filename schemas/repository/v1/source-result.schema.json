{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/source-result.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository source result",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "candidates",
        "line_ranges",
        "byte_ranges"
    ],
    "properties": {
        "candidates": {
            "type": "array",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/candidate.schema.json"
            }
        },
        "source_location": {
            "type": "string",
            "minLength": 1
        },
        "source_digest": {
            "type": "string",
            "minLength": 1
        },
        "line_ranges": {
            "type": "array",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/source-range.schema.json"
            }
        },
        "byte_ranges": {
            "type": "array",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/byte-range.schema.json"
            }
        },
        "estimated_token_count": {
            "type": "integer",
            "minimum": 0
        },
        "truncated": {
            "type": "boolean"
        }
    }
}