{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/error.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository error",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "code",
        "category",
        "message",
        "retryable",
        "operation_id",
        "repository_session_id",
        "repository_version",
        "workspace_version",
        "diagnostics",
        "artifact_references"
    ],
    "properties": {
        "code": {
            "type": "string",
            "minLength": 1
        },
        "category": {
            "type": "string",
            "enum": [
                "protocol",
                "authorization",
                "session",
                "version",
                "repository",
                "indexing",
                "parsing",
                "search",
                "graph",
                "representation",
                "resource",
                "persistence",
                "cancellation",
                "internal"
            ]
        },
        "message": {
            "type": "string",
            "minLength": 1
        },
        "retryable": {
            "type": "boolean"
        },
        "operation_id": {
            "type": "string",
            "minLength": 1
        },
        "repository_session_id": {
            "type": "string",
            "minLength": 1
        },
        "repository_version": {
            "type": "object"
        },
        "workspace_version": {
            "type": "object"
        },
        "diagnostics": {
            "type": "array",
            "items": {
                "$ref": "./diagnostic.schema.json"
            }
        },
        "artifact_references": {
            "type": "array",
            "items": {
                "$ref": "../artifact/v1/reference.schema.json"
            }
        },
        "cause_error_id": {
            "type": "string",
            "minLength": 1
        }
    }
}