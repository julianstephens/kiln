{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/protocol-response.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository protocol response",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "artifact_references",
        "protocol_version",
        "request_id",
        "operation",
        "status"
    ],
    "properties": {
        "protocol_version": {
            "type": "string",
            "const": "1"
        },
        "request_id": {
            "type": "string",
            "minLength": 1
        },
        "operation": {
            "type": "string",
            "minLength": 1
        },
        "status": {
            "type": "string",
            "enum": [
                "ok",
                "not_found",
                "invalid_request",
                "denied",
                "stale_session",
                "conflict",
                "cancelled",
                "exhausted",
                "retryable_error",
                "fatal_error"
            ]
        },
        "repository_id": {
            "type": "string",
            "minLength": 1
        },
        "repository_version_id": {
            "type": "string",
            "minLength": 1
        },
        "workspace_version_id": {
            "type": "string",
            "minLength": 1
        },
        "result": {
            "type": "object"
        },
        "error": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/error.schema.json"
        },
        "usage": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/usage.schema.json"
        },
        "diagnostic": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/diagnostic.schema.json"
        },
        "artifact_references": {
            "type": "array",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
            }
        }
    }
}