{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/protocol-response.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository protocol response",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/common/v1/protocol-response.schema.json"
        },
        {
            "required": [
                "artifact_references"
            ],
            "properties": {
                "operation": {
                    "type": "string",
                    "pattern": "^repository\\."
                },
                "repository": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/identifier.schema.json"
                },
                "error": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/error.schema.json"
                },
                "usage": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/usage.schema.json"
                },
                "diagnostics": {
                    "type": "array",
                    "items": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/diagnostic.schema.json"
                    }
                },
                "artifact_references": {
                    "type": "array",
                    "items": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
                    }
                }
            }
        }
    ]
}