{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/source-request.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository source request",
    "type": "object",
    "unevaluatedProperties": false,
    "allOf": [
        {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/protocol-request.schema.json"
        },
        {
            "properties": {
                "operation": {
                    "const": "repository.get_source"
                },
                "payload": {
                    "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/source-request-payload.schema.json"
                }
            },
            "required": [
                "run_id",
                "session_id",
                "deadline"
            ]
        }
    ]
}