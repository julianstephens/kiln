{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/relevance.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository relevance",
    "description": "Search and ranking metadata describing why a repository candidate is relevant to a query.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "match_terms",
        "lexical_score",
        "semantic_score",
        "hybrid_score",
        "graph_distance",
        "rank",
        "score_explanation"
    ],
    "properties": {
        "lexical_score": {
            "type": "integer",
            "minimum": 0
        },
        "semantic_score": {
            "type": "integer",
            "minimum": 0
        },
        "hybrid_score": {
            "type": "integer",
            "minimum": 0
        },
        "graph_distance": {
            "type": "integer",
            "minimum": 0
        },
        "match_terms": {
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "rank": {
            "type": "integer",
            "minimum": 1
        },
        "score_explanation": {
            "type": "string",
            "minLength": 1
        }
    }
}
