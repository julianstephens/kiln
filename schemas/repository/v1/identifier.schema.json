{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/repository/v1/identifier.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln repository identifier",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "id",
        "version_id",
        "workspace_version_id"
    ],
    "properties": {
        "id": {
            "type": "string",
            "minLength": 1
        },
        "workspace_id": {
            "type": "string",
            "minLength": 1
        },
        "version_id": {
            "type": "string",
            "minLength": 1
        },
        "workspace_version_id": {
            "type": "string",
            "minLength": 1
        }
    }
}