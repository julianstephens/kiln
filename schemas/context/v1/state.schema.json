{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/context/v1/state.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln context state",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "context_id",
        "current_token_estimate",
        "model_context_limit",
        "context_state_revision"
    ],
    "properties": {
        "context_id": {
            "type": "string",
            "minLength": 1
        },
        "pinned_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "available_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "active_item_ids": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "item_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "order": {
                        "type": "integer",
                        "minimum": 0
                    }
                },
                "required": [
                    "item_id",
                    "order"
                ]
            },
            "uniqueItems": true
        },
        "observed_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "stale_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "current_token_estimate": {
            "type": "integer",
            "minimum": 0
        },
        "model_context_limit": {
            "type": "integer",
            "minimum": 0
        },
        "context_state_revision": {
            "type": "integer",
            "minimum": 0
        }
    }
}