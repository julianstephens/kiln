{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/common/v1/source-range.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln common source range",
    "description": "Line and column source range within a repository file or generated source representation.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "start",
        "end"
    ],
    "properties": {
        "start": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "line",
                "column"
            ],
            "properties": {
                "line": {
                    "type": "integer",
                    "minimum": 1
                },
                "column": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "end": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "line",
                "column"
            ],
            "properties": {
                "line": {
                    "type": "integer",
                    "minimum": 1
                },
                "column": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        }
    }
}
