{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/common/v1/protocol-request.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln common protocol request",
    "type": "object",
    "required": [
        "protocol_version",
        "request_id",
        "operation",
        "payload"
    ],
    "properties": {
        "protocol_version": {
            "type": "string",
            "const": "1"
        },
        "request_id": {
            "type": "string",
            "minLength": 1
        },
        "operation": {
            "type": "string",
            "minLength": 1
        },
        "payload": {
            "type": "object"
        },
        "correlation_id": {
            "type": "string",
            "minLength": 1
        },
        "deadline": {
            "type": "string",
            "format": "date-time"
        }
    }
}