{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/run/v1/task-provenance.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln run task provenance",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "source_kind",
        "source_id",
        "trusted",
        "created_at"
    ],
    "properties": {
        "source_kind": {
            "type": "string",
            "minLength": 1
        },
        "source_id": {
            "type": "string",
            "minLength": 1
        },
        "trusted": {
            "type": "boolean"
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        }
    }
}