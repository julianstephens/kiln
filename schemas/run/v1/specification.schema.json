{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/run/v1/specification.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln run specification",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "repository",
        "task_specification",
        "model_configuration",
        "budget_limits",
        "security_profile",
        "output_mode",
        "caller_metadata"
    ],
    "properties": {
        "repository": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/identifier.schema.json"
        },
        "task_specification": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/run/v1/task-specification.schema.json"
        },
        "model_configuration": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/model/v1/configuration.schema.json"
        },
        "budget_limits": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/budget/v1/limits.schema.json"
        },
        "security_profile": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/capability/v1/security-profile.schema.json"
        },
        "validation": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "profile_id": {
                    "type": "string",
                    "minLength": 1
                },
                "requirements": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/validation/v1/requirement.schema.json"
                    }
                }
            }
        },
        "output_mode": {
            "type": "string",
            "enum": [
                "answer",
                "patch",
                "answer_with_patch",
                "report"
            ]
        },
        "caller_metadata": {
            "description": "Caller-supplied opaque metadata. Kiln does not interpret this object.",
            "type": "object"
        },
        "idempotency_key": {
            "type": "string",
            "minLength": 1
        }
    }
}