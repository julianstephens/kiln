{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/run/v1/task-specification.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln run task specification",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "description",
        "success_criteria",
        "constraints",
        "deliverables",
        "provenance"
    ],
    "properties": {
        "description": {
            "type": "string",
            "minLength": 1
        },
        "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "constraints": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "targets": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "issue_references": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "workflow_references": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "deliverables": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "provenance": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/run/v1/task-provenance.schema.json"
        }
    }
}