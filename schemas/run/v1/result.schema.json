{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/run/v1/result.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln run result",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "run_id",
        "terminal_status",
        "stop_reason",
        "answer",
        "answer_artifact",
        "patch_artifact",
        "changed_file_manifest_reference",
        "validation_report_reference",
        "usage",
        "event_stream_range",
        "event_stream_reference",
        "context_ledger_reference"
    ],
    "properties": {
        "run_id": {
            "type": "string",
            "minLength": 1
        },
        "terminal_status": {
            "type": "string",
            "enum": [
                "completed",
                "failed",
                "canceled",
                "exhausted"
            ]
        },
        "stop_reason": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/run/v1/stop-reason.schema.json"
        },
        "answer": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "content_type": {
                    "type": "string",
                    "enum": [
                        "text/plain",
                        "text/markdown",
                        "application/json"
                    ]
                },
                "content": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "required": [
                "content_type",
                "content"
            ]
        },
        "answer_artifact": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/answer-reference.schema.json"
        },
        "patch_artifact": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/patch-reference.schema.json"
        },
        "changed_file_manifest_reference": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/changed-file-manifest-reference.schema.json"
        },
        "validation_report_reference": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/validation-report-reference.schema.json"
        },
        "usage": {
            "type": "object"
        },
        "event_stream_range": {
            "type": "object"
        },
        "event_stream_reference": {
            "type": "string",
            "minLength": 1
        },
        "context_ledger_reference": {
            "type": "string",
            "minLength": 1
        },
        "additional_artifact_references": {
            "type": "array",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
            },
            "uniqueItems": true
        }
    },
    "allOf": [
        {
            "anyOf": [
                {
                    "required": [
                        "event_stream_range"
                    ]
                },
                {
                    "required": [
                        "event_stream_reference"
                    ]
                }
            ]
        },
        {
            "anyOf": [
                {
                    "required": [
                        "answer"
                    ]
                },
                {
                    "required": [
                        "answer_artifact"
                    ]
                }
            ]
        }
    ]
}