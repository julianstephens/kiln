                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/model-request-rendered.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "model.egress_evaluated"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
