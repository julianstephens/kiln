{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/envelope.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event envelope",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "event_id",
        "event_schema_version",
        "sequence",
        "event_type",
        "occurred_at",
        "producer",
        "payload"
    ],
    "properties": {
        "event_id": {
            "type": "string",
            "description": "A globally unique identifier with the installation or tenant scope for this event",
            "minLength": 1
        },
        "event_schema_version": {
            "type": "string",
            "description": "The version of the event schema for this event_type.",
            "minLength": 1
        },
        "run_id": {
            "type": "string",
            "description": "The run that this event is associated with",
            "minLength": 1
        },
        "sequence": {
            "type": "integer",
            "description": "The monotonically increasing sequence number of this event within the run",
            "minimum": 1
        },
        "event_type": {
            "type": "string",
            "description": "The type of event being reported",
            "enum": [
                "run.created",
                "run.initialization_started",
                "run.initialization_completed",
                "run.execution_started",
                "run.output_production_started",
                "run.output_production_completed",
                "run.completed",
                "run.failed",
                "runtime.session_started",
                "runtime.session_ready",
                "repository.preparation_started",
                "repository.version_pinned",
                "repository.preparation_completed",
                "repository.worker_started",
                "repository.session_opened",
                "repository.query_started",
                "repository.query_completed",
                "repository.query_failed",
                "context.plan_requested",
                "context.plan_produced",
                "context.plan_applied",
                "context.item_available",
                "context.item_admitted",
                "context.item_evicted",
                "context.rendered"
            ]
        },
        "occurred_at": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of when this event was generated"
        },
        "producer": {
            "type": "string",
            "description": "The identifier of the logical component that generated this event",
            "minLength": 1
        },
        "payload": {
            "type": "object",
            "description": "The payload of the event, which varies based on the event type"
        },
        "causation_id": {
            "type": "string",
            "description": "The event_id of the event that caused this event to be generated, if applicable",
            "minLength": 1
        },
        "correlation_id": {
            "type": "string",
            "description": "An identifier that can be used to correlate this event with other events, if applicable",
            "minLength": 1
        },
        "operation_id": {
            "type": "string",
            "description": "An identifier that can be used to associate this event with a specific operation, if applicable",
            "minLength": 1
        },
        "turn_id": {
            "type": "string",
            "description": "An identifier that can be used to associate this event with a specific turn, if applicable",
            "minLength": 1
        },
        "repository_session_id": {
            "type": "string",
            "description": "An identifier that can be used to associate this event with a specific repository session, if applicable",
            "minLength": 1
        },
        "artifact_references": {
            "type": "array",
            "description": "References to any artifacts that are associated with this event",
            "items": {
                "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
            },
            "minItems": 1
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "event_type": {
                        "pattern": "^run\\."
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "required": [
                    "run_id"
                ]
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.created"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-created.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.initialization_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-initialization-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.initialization_completed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-initialization-completed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.execution_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-execution-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.output_production_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-output-production-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.output_production_completed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-output-production-completed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.completed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-completed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "run.failed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/run-failed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "runtime.session_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/runtime-session-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "runtime.session_ready"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/runtime-session-ready.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.preparation_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-preparation-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.version_pinned"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-version-pinned.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.preparation_completed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-preparation-completed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.worker_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-worker-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.session_opened"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-session-opened.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.query_started"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-query-started.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.query_completed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-query-completed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "repository.query_failed"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-query-failed.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.plan_requested"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-plan-requested.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.plan_produced"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-plan-produced.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.plan_applied"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-plan-applied.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.item_available"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-item-available.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.item_admitted"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-item-admitted.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.item_evicted"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-item-evicted.schema.json"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "event_type": {
                        "const": "context.rendered"
                    }
                },
                "required": [
                    "event_type"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-rendered.schema.json"
                    }
                }
            }
        }
    ]
}