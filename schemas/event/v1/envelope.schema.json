            },
            "then": {
                "allOf": [
                    {
                        "properties": {
                            "payload": {
                                "$ref": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/artifact-created.schema.json"
                            }
                        }
                    },
                    {
                        "oneOf": [
                            {
                                "required": [
                                    "run_id"
                                ]
                            },
                            {
                                "required": [
                                    "artifact.run_id"
                                ]
                            }
                        ]
                    }
                ]
            }
