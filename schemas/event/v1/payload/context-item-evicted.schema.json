{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-item-evicted.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload context item evicted",
    "description": "Payload for context.item_evicted events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "context_id",
        "item_id",
        "eviction_reason",
        "context_state_revision"
    ],
    "properties": {
        "context_id": {
            "type": "string",
            "minLength": 1
        },
        "item_id": {
            "type": "string",
            "minLength": 1
        },
        "eviction_reason": {
            "type": "string",
            "enum": [
                "token_budget",
                "stale",
                "superseded",
                "low_relevance",
                "manual",
                "plan_applied",
                "context_reset"
            ]
        },
        "context_plan_id": {
            "type": "string",
            "minLength": 1
        },
        "previous_order": {
            "type": "integer",
            "minimum": 0
        },
        "estimated_tokens_freed": {
            "type": "integer",
            "minimum": 0
        },
        "current_token_estimate": {
            "type": "integer",
            "minimum": 0
        },
        "context_state_revision": {
            "type": "integer",
            "minimum": 0
        }
    }
}