{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/repository-preparation-started.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload repository preparation started",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "repository",
        "requested_revision",
        "expected_digest",
        "indexing_configuration_id",
        "requested_refresh_policy"
    ],
    "properties": {
        "repository": {
            "description": "The repository that is being prepared.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/repository/v1/identifier.schema.json"
        },
        "requested_revision": {
            "description": "The revision that is being prepared.",
            "type": "string",
            "minLength": 1
        },
        "expected_digest": {
            "description": "The expected digest of the repository at the requested revision.",
            "type": "string",
            "minLength": 1
        },
        "indexing_configuration_id": {
            "description": "The identifier of the indexing configuration that is being used to prepare the repository.",
            "type": "string",
            "minLength": 1
        },
        "requested_refresh_policy": {
            "description": "Policy describing when this runtime session readiness description should be refreshed.",
            "type": "object",
            "additionalProperties": false,
            "required": [
                "mode"
            ],
            "properties": {
                "mode": {
                    "description": "How readiness metadata is refreshed.",
                    "type": "string",
                    "enum": [
                        "static",
                        "time_based",
                        "event_driven",
                        "manual"
                    ]
                },
                "ttl_seconds": {
                    "description": "How long this readiness metadata should be considered fresh. Required for time_based refresh.",
                    "type": "integer",
                    "minimum": 1
                },
                "refresh_after": {
                    "description": "Absolute timestamp after which this readiness metadata should be refreshed.",
                    "type": "string",
                    "format": "date-time"
                },
                "refresh_triggers": {
                    "description": "Events or conditions that should cause this readiness metadata to be refreshed.",
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "adapter_registered",
                            "adapter_removed",
                            "adapter_health_changed",
                            "protocol_capability_changed",
                            "database_schema_changed",
                            "configuration_changed",
                            "runtime_upgraded"
                        ]
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "last_refreshed_at": {
                    "description": "When this readiness metadata was last refreshed.",
                    "type": "string",
                    "format": "date-time"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "mode": {
                                "const": "time_based"
                            }
                        },
                        "required": [
                            "mode"
                        ]
                    },
                    "then": {
                        "anyOf": [
                            {
                                "required": [
                                    "ttl_seconds"
                                ]
                            },
                            {
                                "required": [
                                    "refresh_after"
                                ]
                            }
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "mode": {
                                "const": "event_driven"
                            }
                        },
                        "required": [
                            "mode"
                        ]
                    },
                    "then": {
                        "required": [
                            "refresh_triggers"
                        ]
                    }
                }
            ]
        }
    }
}