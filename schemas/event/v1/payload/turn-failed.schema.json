{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/turn-failed.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload turn failed",
    "description": "Payload for turn.failed events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "turn_id",
        "turn_index",
        "failure_category",
        "error",
        "failed_at"
    ],
    "properties": {
        "turn_id": {
            "description": "Identity for the turn that failed.",
            "type": "string",
            "minLength": 1
        },
        "turn_index": {
            "description": "Zero-based index of this turn within the run.",
            "type": "integer",
            "minimum": 0
        },
        "failure_category": {
            "description": "Normalized category of turn failure.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/run/v1/error-category.schema.json"
        },
        "error": {
            "description": "Run-level error describing the turn failure.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/run/v1/error.schema.json"
        },
        "partial_output_reference": {
            "description": "Optional artifact reference for partial turn output produced before failure.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
        },
        "model_invocation_ids": {
            "description": "Model invocations attempted during this turn.",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "tool_call_ids": {
            "description": "Tool calls attempted or processed during this turn.",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "context_state_revision": {
            "description": "Context state revision observed when the turn failed.",
            "type": "integer",
            "minimum": 0
        },
        "budget_usage": {
            "description": "Budget usage committed before this turn failed.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/budget/v1/usage.schema.json"
        },
        "retryable": {
            "description": "Whether this turn failure may be retried.",
            "type": "boolean"
        },
        "failed_at": {
            "description": "When the turn failed.",
            "type": "string",
            "format": "date-time"
        }
    }
}