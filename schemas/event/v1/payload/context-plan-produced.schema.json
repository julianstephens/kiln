{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-plan-produced.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload context plan produced",
    "description": "Payload for context.plan_produced events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "context_id",
        "context_plan_request_id",
        "context_plan_id",
        "planned_active_items",
        "estimated_token_count"
    ],
    "properties": {
        "context_id": {
            "type": "string",
            "minLength": 1
        },
        "context_plan_request_id": {
            "type": "string",
            "minLength": 1
        },
        "context_plan_id": {
            "type": "string",
            "minLength": 1
        },
        "planning_strategy": {
            "type": "string",
            "enum": [
                "recency",
                "relevance",
                "pinned_first",
                "budget_fit",
                "hybrid",
                "manual"
            ]
        },
        "planned_active_items": {
            "description": "Items selected by the produced context plan, in intended render order.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "item_id",
                    "order",
                    "admission_reason"
                ],
                "properties": {
                    "item_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "order": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "estimated_tokens": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "admission_reason": {
                        "type": "string",
                        "enum": [
                            "pinned",
                            "recent",
                            "relevant",
                            "required",
                            "dependency",
                            "manual"
                        ]
                    }
                }
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "planned_evictions": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "item_id",
                    "eviction_reason"
                ],
                "properties": {
                    "item_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "eviction_reason": {
                        "type": "string",
                        "enum": [
                            "token_budget",
                            "stale",
                            "superseded",
                            "low_relevance",
                            "manual"
                        ]
                    }
                }
            },
            "uniqueItems": true
        },
        "estimated_token_count": {
            "type": "integer",
            "minimum": 0
        },
        "model_context_limit": {
            "type": "integer",
            "minimum": 0
        },
        "plan_artifact_reference": {
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
        }
    }
}