{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/context-plan-applied.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload context plan applied",
    "description": "Payload for context.plan_applied events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "context_id",
        "context_plan_id",
        "context_state_revision",
        "active_items",
        "current_token_estimate",
        "model_context_limit"
    ],
    "properties": {
        "context_id": {
            "type": "string",
            "minLength": 1
        },
        "context_plan_id": {
            "type": "string",
            "minLength": 1
        },
        "context_state_revision": {
            "type": "integer",
            "minimum": 0
        },
        "active_items": {
            "description": "Active context items after applying the plan.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "item_id",
                    "order"
                ],
                "properties": {
                    "item_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "order": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "estimated_tokens": {
                        "type": "integer",
                        "minimum": 0
                    }
                }
            },
            "uniqueItems": true
        },
        "admitted_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "evicted_item_ids": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "current_token_estimate": {
            "type": "integer",
            "minimum": 0
        },
        "model_context_limit": {
            "type": "integer",
            "minimum": 0
        }
    }
}