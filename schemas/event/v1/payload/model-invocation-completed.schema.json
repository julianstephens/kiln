{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kiln.cyborgdev.cloud/schemas/event/v1/payload/model-invocation-completed.schema.json",
    "x-kiln-schema-release": "1.0.0",
    "title": "Kiln event payload model invocation completed",
    "description": "Payload for model.invocation_completed events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "model_invocation_id",
        "response_artifact_reference",
        "finish_reason",
        "usage",
        "completed_at"
    ],
    "properties": {
        "model_invocation_id": {
            "description": "Model invocation that completed.",
            "type": "string",
            "minLength": 1
        },
        "response_artifact_reference": {
            "description": "Artifact reference for the raw model response.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/artifact/v1/reference.schema.json"
        },
        "finish_reason": {
            "description": "Provider or adapter normalized finish reason.",
            "type": "string",
            "enum": [
                "stop",
                "length",
                "tool_call",
                "content_filter",
                "error",
                "unknown"
            ]
        },
        "usage": {
            "description": "Model usage recorded for this invocation.",
            "type": "object",
            "additionalProperties": false,
            "required": [
                "input_tokens",
                "output_tokens"
            ],
            "properties": {
                "input_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "output_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "cached_input_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "reasoning_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "total_tokens": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "budget_usage": {
            "description": "Budget usage committed for this model invocation.",
            "$ref": "https://kiln.cyborgdev.cloud/schemas/budget/v1/usage.schema.json"
        },
        "latency_ms": {
            "description": "Elapsed invocation latency in milliseconds.",
            "type": "integer",
            "minimum": 0
        },
        "completed_at": {
            "description": "When the model invocation completed.",
            "type": "string",
            "format": "date-time"
        }
    }
}